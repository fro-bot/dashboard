{
  "name": "@fro-bot/dashboard",
  "version": "0.0.0",
  "private": true,
  "description": "Read-only Fro Bot monitoring dashboard",
  "type": "module",
  "scripts": {
    "bootstrap": "pnpm install",
    "dev": "node --env-file-if-exists=.env --watch src/server.ts",
    "dev:fixture": "pnpm build:web:fixture && NODE_ENV=development DASHBOARD_HOST=127.0.0.1 DASHBOARD_WEB_DIST=./web/dist-fixture DASHBOARD_FIXTURE_HARNESS_ENABLED=true DASHBOARD_DEV_AUTOLOGIN=true node --env-file-if-exists=.env src/server.ts",
    "start": "node src/server.ts",
    "build:web": "vite build web",
    "build:web:fixture": "VITE_FIXTURE_MODE=true vite build web",
    "check-types": "tsc --noEmit && tsc --noEmit -p web/tsconfig.json && tsc --noEmit -p .opencode/tsconfig.json",
    "lint": "eslint",
    "fix": "eslint --fix",
    "pretest": "pnpm build:web",
    "test": "vitest run && vitest run --config web/vitest.config.ts"
  },
  "dependencies": {
    "@bfra.me/es": "0.1.0",
    "@hono/node-server": "^1.14.4",
    "@octokit/auth-app": "8.2.0",
    "@octokit/core": "7.0.6",
    "@octokit/graphql": "9.0.3",
    "@octokit/plugin-retry": "8.1.0",
    "@octokit/plugin-throttling": "11.0.3",
    "arctic": "3.7.0",
    "hono": "^4.7.11",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@bfra.me/eslint-config": "0.51.1",
    "@bfra.me/tsconfig": "0.13.1",
    "@opencode-ai/plugin": "1.17.18",
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "4.3.1",
    "eslint": "10.7.0",
    "eslint-plugin-erasable-syntax-only": "0.4.0",
    "jiti": "2.7.0",
    "jsdom": "29.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10",
    "workbox-build": "7.4.1",
    "workbox-cacheable-response": "7.4.1",
    "workbox-core": "7.4.1",
    "workbox-expiration": "7.4.1",
    "workbox-precaching": "7.4.1",
    "workbox-routing": "7.4.1",
    "workbox-strategies": "7.4.1",
    "workbox-window": "7.4.1"
  },
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24"
  }
}
